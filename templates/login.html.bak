<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Kurtex CRM — Sign In</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #f0f2ff;
    --surface: #ffffff;
    --surface2: #f5f6ff;
    --surface3: #eceeff;
    --border: #dde0f8;
    --border-focus: #6366f1;
    --text: #18181b;
    --text-muted: #6b7280;
    --accent: #6366f1;
    --accent-hover: #4f46e5;
    --accent-light: #eef2ff;
    --accent-2: #8b5cf6;
    --success: #059669;
    --success-bg: #ecfdf5;
    --error: #dc2626;
    --error-bg: #fef2f2;
    --radius: 20px;
    --radius-md: 16px;
    --radius-sm: 12px;
    --radius-xs: 8px;
    --shadow: 0 2px 10px rgba(99,102,241,.08), 0 0 0 1px rgba(99,102,241,.06);
    --font: 'Inter', sans-serif;
    --mono: 'JetBrains Mono', monospace;
  }

  [data-theme="dark"] {
    --bg: #0d0d14;
    --surface: #13131e;
    --surface2: #1a1a28;
    --surface3: #222236;
    --border: #2e2e4a;
    --border-focus: #818cf8;
    --text: #e8e8f4;
    --text-muted: #8b8ba8;
    --accent: #818cf8;
    --accent-hover: #6366f1;
    --accent-light: #1a1a2e;
    --accent-2: #a78bfa;
    --success: #34d399;
    --success-bg: #0a2e20;
    --error: #f87171;
    --error-bg: #2a0e0e;
    --shadow: 0 2px 10px rgba(0,0,0,.4), 0 0 0 1px rgba(255,255,255,.04);
  }

  body {
    font-family: var(--font);
    background: var(--bg);
    min-height: 100vh;
    display: grid;
    grid-template-columns: 1fr 1fr;
    color: var(--text);
    transition: background .3s, color .3s;
  }

  /* HERO */
  .hero { position: relative; overflow: hidden; display: flex; flex-direction: column; justify-content: space-between; padding: 2.5rem; min-height: 100vh; }
  .hero-bg { position: absolute; inset: 0; background-size: cover; background-position: center; transition: background-image .8s ease; }
  .hero-bg::after { content: ''; position: absolute; inset: 0; background: linear-gradient(160deg, rgba(8,8,20,.72) 0%, rgba(30,20,60,.78) 100%); }
  .hero-content, .hero-body, .hero-stats, .img-dots { position: relative; z-index: 1; }
  .brand { display: flex; align-items: center; gap: .75rem; }
  .brand-icon { width: 44px; height: 44px; background: linear-gradient(135deg, #6366f1, #8b5cf6); border-radius: 14px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; box-shadow: 0 4px 16px rgba(99,102,241,.4); }
  .brand-name { font-size: 1.4rem; font-weight: 800; color: white; letter-spacing: -.03em; }
  .brand-sub { font-size: .68rem; font-weight: 600; color: rgba(255,255,255,.45); text-transform: uppercase; letter-spacing: .1em; }
  .hero-badge { display: inline-flex; align-items: center; gap: .4rem; background: rgba(129,140,248,.15); border: 1px solid rgba(129,140,248,.3); color: rgba(255,255,255,.85); border-radius: 100px; padding: .35rem .9rem; font-size: .72rem; font-weight: 600; text-transform: uppercase; letter-spacing: .08em; margin-bottom: 1.5rem; }
  .hero-title { font-size: clamp(2rem, 3.2vw, 2.8rem); font-weight: 800; color: white; line-height: 1.1; letter-spacing: -.03em; margin-bottom: 1rem; }
  .hero-title span { background: linear-gradient(90deg, #a5b4fc, #c4b5fd); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
  .hero-desc { color: rgba(255,255,255,.6); font-size: .95rem; line-height: 1.65; max-width: 340px; }
  .hero-stats { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; }
  .stat-card { background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.1); border-radius: 16px; padding: 1rem; backdrop-filter: blur(12px); }
  .stat-num { font-size: 1.5rem; font-weight: 800; color: white; letter-spacing: -.03em; }
  .stat-label { font-size: .68rem; color: rgba(255,255,255,.45); text-transform: uppercase; letter-spacing: .08em; margin-top: .2rem; }
  .img-dots { position: absolute; bottom: 2.5rem; left: 50%; transform: translateX(-50%); z-index: 2; display: flex; gap: 6px; }
  .img-dot { width: 6px; height: 6px; border-radius: 100px; background: rgba(255,255,255,.3); cursor: pointer; transition: all .3s; }
  .img-dot.active { width: 24px; background: white; }

  /* FORM PANEL */
  .form-panel { display: flex; flex-direction: column; justify-content: center; align-items: center; padding: 2.5rem; overflow-y: auto; min-height: 100vh; background: var(--surface); }
  .form-inner { width: 100%; max-width: 420px; animation: fadeUp .45s ease; }
  .topbar { display: flex; justify-content: flex-end; margin-bottom: 2.5rem; }
  .theme-toggle { width: 38px; height: 38px; border-radius: var(--radius-sm); border: 1.5px solid var(--border); background: var(--surface2); cursor: pointer; display: flex; align-items: center; justify-content: center; color: var(--text-muted); transition: all .2s; }
  .theme-toggle:hover { border-color: var(--accent); color: var(--accent); background: var(--accent-light); }
  .form-header { margin-bottom: 2rem; }
  .form-header h1 { font-size: 1.85rem; font-weight: 800; letter-spacing: -.03em; margin-bottom: .4rem; }
  .form-header p { color: var(--text-muted); font-size: .9rem; }

  /* TABS */
  .tabs { display: flex; background: var(--surface2); border: 1.5px solid var(--border); border-radius: var(--radius-sm); padding: 4px; margin-bottom: 1.75rem; gap: 3px; }
  .tab { flex: 1; padding: .6rem .4rem; border: none; border-radius: var(--radius-xs); background: transparent; color: var(--text-muted); font-family: var(--font); font-weight: 600; font-size: .75rem; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: .3rem; transition: all .2s; white-space: nowrap; }
  .tab.active { background: var(--surface); color: var(--accent); box-shadow: var(--shadow); }
  .tab:hover:not(.active) { color: var(--text); }

  /* PANELS */
  .tab-panel { display: none; }
  .tab-panel.active { display: block; animation: fadeUp .22s ease; }

  /* TELEGRAM */
  .tg-wrap { background: var(--surface2); border: 1.5px solid var(--border); border-radius: var(--radius-md); padding: 2rem; text-align: center; }
  .tg-icon-wrap { width: 60px; height: 60px; background: linear-gradient(135deg, #2AABEE, #229ED9); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1rem; box-shadow: 0 4px 16px rgba(42,171,238,.3); }
  .tg-title { font-size: 1.05rem; font-weight: 700; margin-bottom: .4rem; }
  .tg-desc { color: var(--text-muted); font-size: .85rem; margin-bottom: 1.5rem; line-height: 1.55; }
  #tg-widget { display: flex; justify-content: center; }

  /* OTP */
  #otp-step { display: none; animation: fadeUp .25s ease; }
  .otp-hint { background: var(--accent-light); border: 1px solid rgba(99,102,241,.2); border-radius: var(--radius-sm); padding: .85rem 1rem; font-size: .85rem; color: var(--accent); margin-bottom: 1.25rem; display: flex; align-items: flex-start; gap: .5rem; line-height: 1.5; }
  [data-theme="dark"] .otp-hint { border-color: rgba(129,140,248,.3); }

  /* FIELDS */
  .field { margin-bottom: 1.1rem; }
  .field label { display: flex; align-items: center; gap: .4rem; font-size: .75rem; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: .07em; margin-bottom: .45rem; }
  .input-wrap { position: relative; }
  .input-icon { position: absolute; left: .9rem; top: 50%; transform: translateY(-50%); color: var(--text-muted); pointer-events: none; width: 16px; height: 16px; }
  input[type="text"], input[type="password"] {
    width: 100%; padding: .82rem 1rem .82rem 2.6rem;
    border: 1.5px solid var(--border); border-radius: var(--radius-sm);
    font-size: .95rem; font-family: var(--font);
    background: var(--surface2); color: var(--text);
    transition: all .2s; outline: none; -webkit-appearance: none;
  }
  input:focus { border-color: var(--accent); background: var(--surface); box-shadow: 0 0 0 3px rgba(99,102,241,.12); }
  input::placeholder { color: var(--text-muted); opacity: .6; }
  input[readonly] { background: var(--accent-light); border-color: var(--accent); color: var(--accent); cursor: default; font-family: var(--mono); }

  /* BUTTONS */
  .btn-primary { width: 100%; padding: .9rem 1.5rem; background: linear-gradient(135deg, #6366f1, #8b5cf6); color: white; border: none; border-radius: var(--radius-sm); font-family: var(--font); font-size: .95rem; font-weight: 700; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: .5rem; transition: all .2s; margin-top: .5rem; box-shadow: 0 4px 14px rgba(99,102,241,.3); }
  .btn-primary:hover { transform: translateY(-1px); box-shadow: 0 6px 20px rgba(99,102,241,.4); }
  .btn-primary:active { transform: translateY(0); }
  .btn-primary.loading { opacity: .7; pointer-events: none; }
  .btn-secondary { width: 100%; padding: .8rem 1.5rem; background: var(--surface2); color: var(--text-muted); border: 1.5px solid var(--border); border-radius: var(--radius-sm); font-family: var(--font); font-size: .9rem; font-weight: 600; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: .5rem; transition: all .2s; margin-top: .5rem; }
  .btn-secondary:hover { border-color: var(--accent); color: var(--accent); background: var(--accent-light); }

  /* ALERTS */
  .alert { display: none; padding: .75rem 1rem; border-radius: var(--radius-sm); font-size: .85rem; font-weight: 500; margin-top: .75rem; align-items: center; gap: .5rem; }
  .alert.visible { display: flex; }
  .alert-error { background: var(--error-bg); border: 1px solid rgba(220,38,38,.2); color: var(--error); }
  .alert-success { background: var(--success-bg); border: 1px solid rgba(5,150,105,.2); color: var(--success); }
  [data-theme="dark"] .alert-success { border-color: rgba(52,211,153,.2); }

  /* DIVIDER */
  .divider { display: flex; align-items: center; gap: .75rem; margin: 1.25rem 0; color: var(--text-muted); font-size: .75rem; font-weight: 600; text-transform: uppercase; letter-spacing: .08em; }
  .divider::before, .divider::after { content: ''; flex: 1; height: 1px; background: var(--border); }

  /* STEP HINT */
  .step-hint { background: var(--accent-light); border: 1px solid rgba(99,102,241,.2); border-radius: var(--radius-sm); padding: .75rem 1rem; color: var(--accent); font-size: .83rem; margin-bottom: 1rem; display: flex; align-items: flex-start; gap: .5rem; line-height: 1.45; }
  [data-theme="dark"] .step-hint { border-color: rgba(129,140,248,.25); }

  /* SPINNER */
  .spinner { width: 16px; height: 16px; border: 2px solid rgba(255,255,255,.3); border-top-color: white; border-radius: 50%; animation: spin .7s linear infinite; flex-shrink: 0; }

  @media (max-width: 900px) { body { grid-template-columns: 1fr; } .hero { display: none; } .form-panel { padding: 1.5rem; } }
  @media (max-width: 480px) { .form-panel { padding: 1.25rem; } .tab { font-size: .7rem; padding: .5rem .3rem; } }

  @keyframes fadeUp { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
  @keyframes spin { to { transform: rotate(360deg); } }
</style>
</head>
<body>

<!-- HERO -->
<div class="hero">
  <div class="hero-bg" id="heroBg" style="background-image:url('https://images.unsplash.com/photo-1601584115197-04ecc0da31d7?w=1200&q=80')"></div>
  <div class="hero-content">
    <div class="brand">
      <div class="brand-icon"><i data-lucide="truck" style="width:20px;height:20px;color:white;"></i></div>
      <div><div class="brand-name">Kurtex</div><div class="brand-sub">CRM Platform</div></div>
    </div>
  </div>
  <div class="hero-body" style="padding-bottom:1rem;">
    <div class="hero-badge"><i data-lucide="zap" style="width:11px;height:11px;"></i> Trucking Operations Platform</div>
    <h2 class="hero-title">Control Your<br><span>Fleet Intelligence</span><br>From One Place</h2>
    <p class="hero-desc">Manage cases, track drivers, coordinate agents — all in real time. Built for the modern logistics team.</p>
  </div>
  <div class="hero-stats">
    <div class="stat-card"><div class="stat-num">2.4k+</div><div class="stat-label">Cases Resolved</div></div>
    <div class="stat-card"><div class="stat-num">98%</div><div class="stat-label">Uptime SLA</div></div>
    <div class="stat-card"><div class="stat-num">4 min</div><div class="stat-label">Avg. Response</div></div>
  </div>
  <div class="img-dots">
    <div class="img-dot active" onclick="setImg(0)"></div>
    <div class="img-dot" onclick="setImg(1)"></div>
    <div class="img-dot" onclick="setImg(2)"></div>
  </div>
</div>

<!-- FORM -->
<div class="form-panel">
  <div class="form-inner">
    <div class="topbar">
      <button class="theme-toggle" onclick="toggleTheme()" title="Toggle theme">
        <i data-lucide="moon" id="themeIcon" style="width:16px;height:16px;"></i>
      </button>
    </div>
    <div class="form-header">
      <h1>Welcome back</h1>
      <p>Sign in to access your Kurtex workspace</p>
    </div>

    <div class="tabs" role="tablist">
      <button class="tab active" onclick="switchTab('telegram',this)"><i data-lucide="send" style="width:13px;height:13px;"></i> Telegram</button>
      <button class="tab" onclick="switchTab('login',this)"><i data-lucide="key-round" style="width:13px;height:13px;"></i> Password</button>
      <button class="tab" onclick="switchTab('register',this)"><i data-lucide="user-plus" style="width:13px;height:13px;"></i> Register</button>
      <button class="tab" onclick="switchTab('reset',this)"><i data-lucide="rotate-ccw" style="width:13px;height:13px;"></i> Reset</button>
    </div>

    <!-- TELEGRAM TAB -->
    <div class="tab-panel active" id="panel-telegram">
      <div id="tg-step-widget">
        <div class="tg-wrap">
          <div class="tg-icon-wrap"><i data-lucide="send" style="width:26px;height:26px;color:white;"></i></div>
          <div class="tg-title">Continue with Telegram</div>
          <div class="tg-desc">Click the button below to authenticate. A one-time code will be sent to your Telegram.</div>
          <div id="tg-widget">
            {% if bot_username %}
            <script async src="https://telegram.org/js/telegram-widget.js?22"
               data-telegram-login="{{ bot_username }}"
               data-size="large"
               data-radius="10"
               data-onauth="onTelegramAuth(user)"
               data-request-access="write">
            </script>
            {% else %}
            <div style="color:var(--text-muted);font-size:.83rem;padding:.5rem 0;">
              ⚠️ Set <code style="font-family:var(--mono);background:var(--surface3);padding:2px 7px;border-radius:6px;">TELEGRAM_BOT_USERNAME</code> env var to enable Telegram login.
            </div>
            {% endif %}
          </div>
        </div>
        <div class="divider">or use credentials</div>
        <button class="btn-secondary" onclick="switchTab('login',document.querySelectorAll('.tab')[1])">
          <i data-lucide="key-round" style="width:15px;height:15px;"></i> Sign In with Password
        </button>
      </div>

      <!-- OTP step shown after widget callback -->
      <div id="otp-step">
        <div class="otp-hint">
          <i data-lucide="message-circle" style="width:15px;height:15px;flex-shrink:0;margin-top:1px;"></i>
          <span>A 6-digit code was sent to your Telegram. Enter it below to complete sign-in.</span>
        </div>
        <div class="field">
          <label><i data-lucide="hash" style="width:13px;height:13px;"></i> OTP Code</label>
          <div class="input-wrap">
            <i data-lucide="hash" class="input-icon"></i>
            <input type="text" id="otp-code" placeholder="123456" maxlength="6" autocomplete="one-time-code"
              onkeydown="if(event.key==='Enter')submitOtp()"
              style="font-family:var(--mono);letter-spacing:.25em;font-size:1.2rem;text-align:center;padding-left:1rem;">
          </div>
        </div>
        <div class="alert alert-error" id="otp-error">
          <i data-lucide="alert-circle" style="width:15px;height:15px;flex-shrink:0;"></i>
          <span id="otp-error-text"></span>
        </div>
        <button class="btn-primary" onclick="submitOtp()" id="otpBtn">
          <i data-lucide="check-circle" style="width:16px;height:16px;"></i> Verify Code
        </button>
        <button class="btn-secondary" onclick="resetOtpStep()">
          <i data-lucide="arrow-left" style="width:14px;height:14px;"></i> Back
        </button>
      </div>
    </div>

    <!-- PASSWORD LOGIN -->
    <div class="tab-panel" id="panel-login">
      <div class="field">
        <label><i data-lucide="at-sign" style="width:13px;height:13px;"></i> Telegram Username</label>
        <div class="input-wrap">
          <i data-lucide="at-sign" class="input-icon"></i>
          <input type="text" id="login-username" placeholder="username" autocomplete="username">
        </div>
      </div>
      <div class="field">
        <label><i data-lucide="lock" style="width:13px;height:13px;"></i> Password</label>
        <div class="input-wrap">
          <i data-lucide="lock" class="input-icon"></i>
          <input type="password" id="login-password" placeholder="••••••••" autocomplete="current-password"
            onkeydown="if(event.key==='Enter')loginWithPw()">
        </div>
      </div>
      <div class="alert alert-error" id="login-error">
        <i data-lucide="alert-circle" style="width:15px;height:15px;flex-shrink:0;"></i>
        <span id="login-error-text"></span>
      </div>
      <button class="btn-primary" onclick="loginWithPw()" id="loginBtn">
        <i data-lucide="log-in" style="width:16px;height:16px;"></i> Sign In
      </button>
      <button class="btn-secondary" onclick="switchTab('reset',document.querySelectorAll('.tab')[3])">
        <i data-lucide="rotate-ccw" style="width:14px;height:14px;"></i> Forgot password?
      </button>
    </div>

    <!-- REGISTER -->
    <div class="tab-panel" id="panel-register">
      <div class="step-hint">
        <i data-lucide="info" style="width:14px;height:14px;flex-shrink:0;margin-top:1px;"></i>
        <span>Your Telegram account must be added by an admin via the bot before you can set a password here.</span>
      </div>
      <div class="field">
        <label><i data-lucide="at-sign" style="width:13px;height:13px;"></i> Telegram Username</label>
        <div class="input-wrap">
          <i data-lucide="at-sign" class="input-icon"></i>
          <input type="text" id="reg-username" placeholder="username">
        </div>
      </div>
      <div class="field">
        <label><i data-lucide="lock" style="width:13px;height:13px;"></i> Password</label>
        <div class="input-wrap">
          <i data-lucide="lock" class="input-icon"></i>
          <input type="password" id="reg-password" placeholder="Min 6 characters"
            onkeydown="if(event.key==='Enter')registerUser()">
        </div>
      </div>
      <div class="alert alert-error" id="reg-error">
        <i data-lucide="alert-circle" style="width:15px;height:15px;flex-shrink:0;"></i>
        <span id="reg-error-text"></span>
      </div>
      <div class="alert alert-success" id="reg-success">
        <i data-lucide="check-circle" style="width:15px;height:15px;flex-shrink:0;"></i>
        <span>Account created! You can now sign in with your password.</span>
      </div>
      <button class="btn-primary" onclick="registerUser()" id="regBtn">
        <i data-lucide="user-plus" style="width:16px;height:16px;"></i> Create Account
      </button>
    </div>

    <!-- RESET -->
    <div class="tab-panel" id="panel-reset">
      <div id="reset-step1">
        <div class="step-hint">
          <i data-lucide="info" style="width:14px;height:14px;flex-shrink:0;margin-top:1px;"></i>
          <span>Enter your Telegram username to generate a one-time reset token.</span>
        </div>
        <div class="field">
          <label><i data-lucide="at-sign" style="width:13px;height:13px;"></i> Telegram Username</label>
          <div class="input-wrap">
            <i data-lucide="at-sign" class="input-icon"></i>
            <input type="text" id="reset-username" placeholder="username">
          </div>
        </div>
        <div class="alert alert-error" id="reset-error">
          <i data-lucide="alert-circle" style="width:15px;height:15px;flex-shrink:0;"></i>
          <span id="reset-error-text"></span>
        </div>
        <button class="btn-primary" onclick="resetPasswordStep1()" id="resetBtn1">
          <i data-lucide="send" style="width:16px;height:16px;"></i> Generate Reset Token
        </button>
      </div>
      <div id="reset-step2" style="display:none;">
        <div class="step-hint">
          <i data-lucide="check-circle" style="width:14px;height:14px;flex-shrink:0;margin-top:1px;"></i>
          <span>Token generated. Copy it and set your new password below.</span>
        </div>
        <div class="field">
          <label><i data-lucide="hash" style="width:13px;height:13px;"></i> Reset Token</label>
          <div class="input-wrap">
            <i data-lucide="hash" class="input-icon"></i>
            <input type="text" id="reset-token" readonly>
          </div>
        </div>
        <div class="field">
          <label><i data-lucide="lock" style="width:13px;height:13px;"></i> New Password</label>
          <div class="input-wrap">
            <i data-lucide="lock" class="input-icon"></i>
            <input type="password" id="reset-newpw" placeholder="Min 6 characters">
          </div>
        </div>
        <div class="field">
          <label><i data-lucide="shield-check" style="width:13px;height:13px;"></i> Confirm Password</label>
          <div class="input-wrap">
            <i data-lucide="shield-check" class="input-icon"></i>
            <input type="password" id="reset-confirmpw" placeholder="Repeat password"
              onkeydown="if(event.key==='Enter')resetPasswordStep2()">
          </div>
        </div>
        <div class="alert alert-error" id="reset-error2">
          <i data-lucide="alert-circle" style="width:15px;height:15px;flex-shrink:0;"></i>
          <span id="reset-error2-text"></span>
        </div>
        <div class="alert alert-success" id="reset-success">
          <i data-lucide="check-circle" style="width:15px;height:15px;flex-shrink:0;"></i>
          <span>Password reset! Redirecting to sign in…</span>
        </div>
        <button class="btn-primary" onclick="resetPasswordStep2()" id="resetBtn2">
          <i data-lucide="shield-check" style="width:16px;height:16px;"></i> Reset Password
        </button>
        <button class="btn-secondary" onclick="resetBack()">
          <i data-lucide="arrow-left" style="width:14px;height:14px;"></i> Back
        </button>
      </div>
    </div>

  </div>
</div>

<script>
lucide.createIcons();

const IMAGES = [
  'https://images.unsplash.com/photo-1601584115197-04ecc0da31d7?w=1200&q=80',
  'https://images.unsplash.com/photo-1586528116311-ad8dd3c8310d?w=1200&q=80',
  'https://images.unsplash.com/photo-1519003722824-194d4455a60c?w=1200&q=80',
];
let currentImg = 0;
function setImg(i) {
  currentImg = i;
  document.getElementById('heroBg').style.backgroundImage = `url('${IMAGES[i]}')`;
  document.querySelectorAll('.img-dot').forEach((d,j) => d.classList.toggle('active', j===i));
}
setInterval(() => setImg((currentImg+1) % IMAGES.length), 6000);

function toggleTheme() {
  const html = document.documentElement;
  const isDark = html.dataset.theme === 'dark';
  html.dataset.theme = isDark ? 'light' : 'dark';
  localStorage.setItem('kurtex-theme', html.dataset.theme);
  document.getElementById('themeIcon').setAttribute('data-lucide', isDark ? 'moon' : 'sun');
  lucide.createIcons();
}
(function(){
  const s = localStorage.getItem('kurtex-theme') ||
    (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
  document.documentElement.dataset.theme = s;
  if (s === 'dark') { document.getElementById('themeIcon').setAttribute('data-lucide','sun'); lucide.createIcons(); }
})();

function switchTab(name, btn) {
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
  if (btn) btn.classList.add('active');
  document.getElementById('panel-'+name).classList.add('active');
}

function showAlert(id, msg, type='error') {
  const el = document.getElementById(id);
  const tx = document.getElementById(id+'-text');
  if (tx) tx.textContent = msg;
  el.className = `alert alert-${type} visible`;
}
function hideAlert(id) { const el = document.getElementById(id); if(el) el.classList.remove('visible'); }

function setLoading(id, on, html) {
  const b = document.getElementById(id);
  if (!b) return;
  b.classList.toggle('loading', on);
  if (on) b.innerHTML = '<div class="spinner"></div>';
  else if (html) { b.innerHTML = html; lucide.createIcons(); }
}

// ── Telegram OTP flow
let _tgUserId = null;
window.onTelegramAuth = async function(user) {
  _tgUserId = parseInt(user.id);
  try {
    const r = await fetch('/auth/telegram', {
      method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify(user)
    });
    const d = await r.json();
    if (d.ok) {
      document.getElementById('tg-step-widget').style.display = 'none';
      document.getElementById('otp-step').style.display = 'block';
      setTimeout(() => document.getElementById('otp-code').focus(), 100);
    } else {
      alert(d.error || 'Authentication failed. Make sure you are registered in the system.');
    }
  } catch(e) { alert('Network error. Please try again.'); }
};

async function submitOtp() {
  const code = document.getElementById('otp-code').value.trim();
  hideAlert('otp-error');
  if (!code || code.length < 6) { showAlert('otp-error', 'Please enter the 6-digit code sent to your Telegram.'); return; }
  setLoading('otpBtn', true);
  try {
    const r = await fetch('/verify-code', {
      method: 'POST', headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({telegram_id: _tgUserId, code})
    });
    const d = await r.json();
    if (d.ok) { window.location = d.redirect; return; }
    showAlert('otp-error', d.error || 'Invalid code. Try again.');
  } catch(e) { showAlert('otp-error', 'Network error.'); }
  setLoading('otpBtn', false, '<i data-lucide="check-circle" style="width:16px;height:16px;"></i> Verify Code');
}

function resetOtpStep() {
  document.getElementById('tg-step-widget').style.display = '';
  document.getElementById('otp-step').style.display = 'none';
  document.getElementById('otp-code').value = '';
  hideAlert('otp-error');
  _tgUserId = null;
}

async function loginWithPw() {
  const u = document.getElementById('login-username').value.trim().replace(/^@/,'');
  const p = document.getElementById('login-password').value;
  hideAlert('login-error');
  if (!u||!p) { showAlert('login-error','Username and password are required.'); return; }
  setLoading('loginBtn', true);
  try {
    const r = await fetch('/login-password', {method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({telegram_username:u, password:p})});
    const d = await r.json();
    if (d.ok) { window.location = d.redirect; return; }
    showAlert('login-error', d.error||'Invalid credentials.');
  } catch(e) { showAlert('login-error','Network error.'); }
  setLoading('loginBtn', false, '<i data-lucide="log-in" style="width:16px;height:16px;"></i> Sign In');
}

async function registerUser() {
  const u = document.getElementById('reg-username').value.trim().replace(/^@/,'');
  const p = document.getElementById('reg-password').value;
  hideAlert('reg-error'); hideAlert('reg-success');
  if (!u||!p||p.length<6) { showAlert('reg-error','Valid username and password (min 6 chars) required.'); return; }
  setLoading('regBtn', true);
  try {
    const r = await fetch('/api/register', {method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({telegram_username:u, password:p})});
    const d = await r.json();
    if (d.ok) { document.getElementById('reg-success').classList.add('visible'); document.getElementById('reg-username').value=''; document.getElementById('reg-password').value=''; }
    else showAlert('reg-error', d.error||'Registration failed.');
  } catch(e) { showAlert('reg-error','Network error.'); }
  setLoading('regBtn', false, '<i data-lucide="user-plus" style="width:16px;height:16px;"></i> Create Account');
}

async function resetPasswordStep1() {
  const u = document.getElementById('reset-username').value.trim().replace(/^@/,'');
  hideAlert('reset-error');
  if (!u) { showAlert('reset-error','Please enter your Telegram username.'); return; }
  setLoading('resetBtn1', true);
  try {
    const r = await fetch('/reset-password', {method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({telegram_username:u})});
    const d = await r.json();
    if (d.ok) {
      document.getElementById('reset-token').value = d.token;
      document.getElementById('reset-step1').style.display = 'none';
      document.getElementById('reset-step2').style.display = 'block';
    } else showAlert('reset-error', d.error||'User not found.');
  } catch(e) { showAlert('reset-error','Network error.'); }
  setLoading('resetBtn1', false, '<i data-lucide="send" style="width:16px;height:16px;"></i> Generate Reset Token');
}

async function resetPasswordStep2() {
  const u = document.getElementById('reset-username').value.trim().replace(/^@/,'');
  const token = document.getElementById('reset-token').value.trim();
  const np = document.getElementById('reset-newpw').value;
  const cp = document.getElementById('reset-confirmpw').value;
  hideAlert('reset-error2'); hideAlert('reset-success');
  if (!np||np.length<6) { showAlert('reset-error2','Password must be at least 6 characters.'); return; }
  if (np!==cp) { showAlert('reset-error2','Passwords do not match.'); return; }
  setLoading('resetBtn2', true);
  try {
    const r = await fetch('/verify-reset', {method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({telegram_username:u, token, password:np})});
    const d = await r.json();
    if (d.ok) {
      document.getElementById('reset-success').classList.add('visible');
      setTimeout(() => switchTab('login', document.querySelectorAll('.tab')[1]), 2000);
    } else showAlert('reset-error2', d.error||'Reset failed.');
  } catch(e) { showAlert('reset-error2','Network error.'); }
  setLoading('resetBtn2', false, '<i data-lucide="shield-check" style="width:16px;height:16px;"></i> Reset Password');
}

function resetBack() {
  document.getElementById('reset-step1').style.display = 'block';
  document.getElementById('reset-step2').style.display = 'none';
  ['reset-token','reset-newpw','reset-confirmpw'].forEach(id => document.getElementById(id).value='');
  ['reset-error','reset-error2','reset-success'].forEach(hideAlert);
}
</script>
</body>
</html>
